<configuration name="xml_curl.conf" description="cURL XML Gateway">
  <bindings>
    <binding name="directory">
      <!-- Allow to bind on a particular IP for requests sent -->
      <!--<param name="bind-local" value="$${local_ip_v4}" />-->
      <!-- The url to a gateway cgi that can generate xml similar to
	   what's in this file only on-the-fly (leave it commented if you dont
	   need it) -->
      <!-- one or more |-delim of configuration|directory|dialplan -->
      <param name="gateway-url" value="$${internal_api_base_url}/directory" bindings="directory"/>
      <!-- set this to provide authentication credentials to the server -->
      <param name="gateway-credentials" value="$${internal_api_username}:$${internal_api_password}"/>
      <param name="auth-scheme" value="basic"/>

      <!-- one or more of these imply you want to pick the exact variables that are transmitted -->
      <!--<param name="enable-post-var" value="Unique-ID"/>-->
    </binding>


    <binding name="configuration">
      <param name="gateway-url" value="$${internal_api_base_url}/configuration" bindings="configuration"/>
      <!-- set this to provide authentication credentials to the server -->
      <param name="gateway-credentials" value="$${internal_api_username}:$${internal_api_password}"/>
      <param name="auth-scheme" value="basic"/>
    </binding>

    <binding name="dialplan">
      <param name="gateway-url" value="$${internal_api_base_url}/dialplan" bindings="dialplan"/>
      <!-- set this to provide authentication credentials to the server -->
      <param name="gateway-credentials" value="$${internal_api_username}:$${internal_api_password}"/>
      <param name="auth-scheme" value="basic"/>
    </binding>
  </bindings>
</configuration>
